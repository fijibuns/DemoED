summarise()
summary_report <- province_winners %>%
group_by(candidate) %>%
summarise(
provinces_won = n(),
total_votes = sum(votes, na.rm = TRUE),
.groups = "drop"
) %>%
mutate(
province_share = round(provinces_won / sum(provinces_won) * 100, 2)
) %>%
arrange(desc(provinces_won))
summary_report
summary_report <- region_winners %>%
group_by(candidate) %>%
summarise(
provinces_won = n(),
total_votes = sum(votes, na.rm = TRUE),
.groups = "drop"
) %>%
mutate(
province_share = round(provinces_won / sum(provinces_won) * 100, 2)
) %>%
arrange(desc(provinces_won))
combined_report
combined_report <- province_winners %>%
group_by(region, candidate) %>%
summarise(
provinces_won = n(),
total_votes = sum(votes, na.rm = TRUE),
.groups = "drop"
) %>%
arrange(region, desc(provinces_won), desc(total_votes))
